{
  "routes": [
    {
      "route": "/api/*",
      "rewrite": "https://bespokelibrary-production.up.railway.app/api/*"
    },
    {
      "route": "/*",
      "allowedRoles": ["anonymous", "authenticated"]
    }
  ],
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": ["/api/*", "*.css", "*.js", "*.json"]
  }
}
