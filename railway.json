{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "cd api && pip3 install -r requirements.txt"
  },
  "deploy": {
    "startCommand": "cd api && gunicorn app:app --bind 0.0.0.0:$PORT --workers 2 --timeout 60",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3
  }
}
